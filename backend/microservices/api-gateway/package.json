    "devDependencies": {
        "@types/express": "^5.0.3",
        "@types/node": "^24.1.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/uuid": "^10.0.0",
        "@types/node-fetch": "^2.6.12",
        "typescript": "^5.8.3",
        "ts-node-dev": "^2.0.0",
        "jest": "^30.0.5",
        "eslint": "^9.32.0"
