{
    "name": "@groupomania/api-gateway",
    "version": "1.0.0",
    "description": "API Gateway pour l'architecture microservices Groupomania",
    "main": "dist/server.js",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "start": "node dist/server.js",
