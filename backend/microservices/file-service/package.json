{
    "name": "groupomania-file-service",
    "version": "1.0.0",
    "description": "Service de gestion de fichiers pour Groupomania - Upload, stockage, traitement d'images et gestion de documents",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "nodemon src/server.ts",
        "build": "tsc",
        "build:watch": "tsc --watch",
        "clean": "rimraf dist",
        "prebuild": "npm run clean",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write src/**/*.ts",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "groupomania",
        "file-service",
        "upload",
        "images",
        "documents",
        "express",
        "typescript"
    ],
    "author": "Groupomania Team",
    "license": "ISC",
    "dependencies": {
        "express": "^5.1.0",
        "cors": "^2.8.5",
        "helmet": "^8.1.0",
        "compression": "^1.8.1",
        "morgan": "^1.10.1",
        "dotenv": "^17.2.1",
        "express-validator": "^7.2.1",
        "express-rate-limit": "^8.0.1",
        "jsonwebtoken": "^9.0.2",
        "bcryptjs": "^3.0.2",
        "multer": "^2.0.2",
        "sharp": "^0.34.3",
        "sequelize": "^6.37.7",
        "sequelize-typescript": "^2.1.6",
        "pg": "^8.16.3",
        "pg-hstore": "^2.3.4",
        "redis": "^5.6.1",
        "node-cron": "^4.2.1",
        "uuid": "^11.1.0",
        "mime-types": "^3.0.1",
        "file-type": "^21.0.0"
    },
    "devDependencies": {
        "@types/node": "^24.1.0",
        "@types/express": "^5.0.3",
        "@types/cors": "^2.8.19",
        "@types/compression": "^1.8.1",
        "@types/morgan": "^1.9.10",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/pg": "^8.15.4",
        "@types/uuid": "^10.0.0",
        "@types/mime-types": "^3.0.1",
        "@types/jest": "^30.0.0",
        "typescript": "^5.8.3",
        "nodemon": "^3.1.10",
        "jest": "^30.0.5",
        "supertest": "^7.1.4",
        "eslint": "^9.32.0",
        "@typescript-eslint/eslint-plugin": "^8.38.0",
        "@typescript-eslint/parser": "^8.38.0",
        "prettier": "^3.6.2"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    }
}