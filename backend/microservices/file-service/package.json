{
    "name": "groupomania-file-service",
    "version": "1.0.0",
    "description": "Service de gestion de fichiers pour Groupomania - Upload, stockage, traitement d'images et gestion de documents",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "build:watch": "tsc --watch",
        "clean": "rimraf dist",
        "prebuild": "npm run clean",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write src/**/*.ts",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "groupomania",
        "file-service",
        "upload",
        "images",
        "documents",
        "express",
        "typescript"
    ],
    "author": "Groupomania Team",
    "license": "ISC",
    "dependencies": {
        "@types/fs-extra": "^11.0.4",
        "bcryptjs": "^3.0.3",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "express-validator": "^7.3.2",
        "file-type": "^22.0.1",
        "fs-extra": "^11.3.6",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.3",
        "mime-types": "^3.0.2",
        "morgan": "^1.11.0",
        "multer": "^2.2.0",
        "node-cron": "^4.6.0",
        "pg": "^8.22.0",
        "pg-hstore": "^2.3.4",
        "redis": "^6.1.0",
        "sequelize": "^6.37.8",
        "sequelize-typescript": "^2.1.6",
        "sharp": "^0.35.3",
        "uuid": "^14.0.1"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mime-types": "^3.0.1",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.2.0",
        "@types/node": "^26.1.1",
        "@types/pg": "^8.20.0",
        "@types/uuid": "^11.0.0",
        "@typescript-eslint/eslint-plugin": "^8.63.0",
        "@typescript-eslint/parser": "^8.63.0",
        "eslint": "^10.6.0",
        "jest": "^30.4.2",
        "nodemon": "^3.1.14",
        "prettier": "^3.9.5",
        "supertest": "^7.2.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    }
}
