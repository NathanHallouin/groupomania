# Configuration du serveur
PORT=3001
NODE_ENV=development

# Configuration de la base de données
DB_HOST=localhost
DB_PORT=5432
DB_NAME=groupomania_auth
DB_USER=postgres
DB_PASSWORD=password

# Configuration JWT
JWT_ACCESS_SECRET=access-secret-key-very-long-and-secure-please-change-in-production
JWT_REFRESH_SECRET=refresh-secret-key-very-long-and-secure-please-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Configuration de sécurité
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=7200000

# Configuration CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:4200
CORS_CREDENTIALS=true

# Configuration des emails (optionnel)
ALLOWED_EMAIL_DOMAINS=groupomania.com,example.com

# Configuration du logging
LOG_LEVEL=info
LOG_FORMAT=combined
