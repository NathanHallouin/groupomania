{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "strictPropertyInitialization": false,
        "baseUrl": "./src",
        "paths": {
            "@/*": [
                "*"
            ],
            "@/types/*": [
                "types/*"
            ],
            "@/models/*": [
                "models/*"
            ],
            "@/controllers/*": [
                "controllers/*"
            ],
            "@/services/*": [
                "services/*"
            ],
            "@/middleware/*": [
                "middleware/*"
            ],
            "@/utils/*": [
                "utils/*"
            ],
            "@/config/*": [
                "config/*"
            ]
        },
        "typeRoots": [
            "./node_modules/@types",
            "./src/types"
        ]
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts",
        "**/*.spec.ts"
    ]
}