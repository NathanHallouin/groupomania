{
    "name": "@groupomania/message-service",
    "version": "1.0.0",
    "description": "Service de gestion des messages et communications temps réel pour Groupomania",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "clean": "rimraf dist"
    },
    "keywords": [
        "groupomania",
        "messages",
        "real-time",
        "websocket",
        "microservice",
        "typescript",
        "postgresql"
    ],
    "author": "Groupomania Development Team",
    "license": "MIT",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^17.2.1",
        "express": "^5.1.0",
        "express-rate-limit": "^8.0.1",
        "express-validator": "^7.2.1",
        "file-type": "^21.0.0",
        "helmet": "^8.1.0",
        "ioredis": "^5.6.1",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.2",
        "mime-types": "^3.0.1",
        "moment": "^2.30.1",
        "morgan": "^1.10.1",
        "multer": "^2.0.2",
        "pg": "^8.16.3",
        "pg-hstore": "^2.3.4",
        "redis": "^5.6.1",
        "sanitize-html": "^2.17.0",
        "sequelize": "^6.37.7",
        "sequelize-typescript": "^2.1.6",
        "sharp": "^0.34.3",
        "socket.io": "^4.8.1",
        "uuid": "^11.1.0",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/ioredis": "^5.0.0",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mime-types": "^3.0.1",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.1.0",
        "@types/sanitize-html": "^2.16.0",
        "@types/supertest": "^6.0.3",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.38.0",
        "@typescript-eslint/parser": "^8.38.0",
        "eslint": "^9.32.0",
        "jest": "^30.0.5",
        "nodemon": "^3.1.10",
        "rimraf": "^6.0.1",
        "supertest": "^7.1.4",
        "typescript": "^5.8.3"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=8.0.0"
    }
