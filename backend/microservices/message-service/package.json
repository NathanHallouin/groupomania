{
    "name": "@groupomania/message-service",
    "version": "1.0.0",
    "description": "Service de gestion des messages et communications temps réel pour Groupomania",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "clean": "rimraf dist"
    },
    "keywords": [
        "groupomania",
        "messages",
        "real-time",
        "websocket",
        "microservice",
        "typescript",
        "postgresql"
    ],
    "author": "Groupomania Development Team",
    "license": "MIT",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "express-validator": "^7.3.2",
        "file-type": "^22.0.1",
        "helmet": "^8.2.0",
        "ioredis": "^5.11.1",
        "joi": "^18.2.3",
        "jsonwebtoken": "^9.0.3",
        "mime-types": "^3.0.2",
        "moment": "^2.30.1",
        "morgan": "^1.11.0",
        "multer": "^2.2.0",
        "pg": "^8.22.0",
        "pg-hstore": "^2.3.4",
        "redis": "^6.1.0",
        "sanitize-html": "^2.17.5",
        "sequelize": "^6.37.8",
        "sequelize-typescript": "^2.1.6",
        "sharp": "^0.35.3",
        "socket.io": "^4.8.3",
        "uuid": "^14.0.1",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/ioredis": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mime-types": "^3.0.1",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.2.0",
        "@types/node": "^26.1.1",
        "@types/sanitize-html": "^2.16.1",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^11.0.0",
        "@typescript-eslint/eslint-plugin": "^8.63.0",
        "@typescript-eslint/parser": "^8.63.0",
        "eslint": "^10.6.0",
        "jest": "^30.4.2",
        "nodemon": "^3.1.14",
        "rimraf": "^6.1.3",
        "supertest": "^7.2.2",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=8.0.0"
    }
