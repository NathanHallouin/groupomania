# Environment Configuration Example for Groupomania Backend
# Copy this file to .env and update the values for your environment

# ==============================
# Environment
# ==============================
NODE_ENV=development
PORT=3001
HOST=localhost
API_VERSION=v1

# ==============================
# Database Configuration - PostgreSQL
# ==============================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=groupomania_development
DB_USERNAME=groupomania
DB_PASSWORD=your-secure-password-here
DB_NAME_TEST=groupomania_test
DB_SSL=false

# Microservices Database Configuration
DB_AUTH=groupomania_auth
DB_USERS=groupomania_users
DB_MESSAGES=groupomania_messages
DB_FILES=groupomania_files

# Database Pool Configuration (Performance Optimization)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_POOL_EVICT=1000

# ==============================
# JWT Configuration
# ==============================
# Generate secure secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-32-chars-minimum
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-secure-refresh-secret-32-chars-minimum
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Configuration
COOKIE_SECRET=your-super-secret-cookie-key-change-this-in-production
COOKIE_EXPIRES_IN=7

# Redis Configuration (for rate limiting and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS Configuration
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# File Upload Configuration
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX_REQUESTS=5
RATE_LIMIT_SIGNUP_WINDOW_MS=3600000
RATE_LIMIT_SIGNUP_MAX_REQUESTS=3

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Security Configuration
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# API Documentation
SWAGGER_TITLE=Groupomania API
SWAGGER_DESCRIPTION=Enterprise Social Network API
SWAGGER_VERSION=3.0.0
SWAGGER_CONTACT_NAME=Groupomania Development Team
SWAGGER_CONTACT_EMAIL=dev@groupomania.com

# Monitoring & Health Check
HEALTH_CHECK_ENDPOINT=/health
METRICS_ENDPOINT=/metrics

# Email Configuration (if needed)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@groupomania.com

# Performance & Caching Configuration
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_CACHE=true
CACHE_DEFAULT_TTL=300
CACHE_MESSAGES_TTL=300
CACHE_USERS_TTL=600
CACHE_STATS_TTL=1800

# Development Tools
ENABLE_SWAGGER=true
ENABLE_CORS=true
ENABLE_REQUEST_LOGGING=true
ENABLE_BENCHMARK=true
